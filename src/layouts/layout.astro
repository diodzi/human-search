---
import { Font } from 'astro:assets'
import { DotIcon } from '@lucide/astro'
import '../styles/global.css'
---

<html lang='en'>
    <head>
        <meta charset='utf-8' />
        <link
            rel='icon'
            href='data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🔍</text></svg>'
        />
        <meta name='viewport' content='width=device-width' />
        <meta name='generator' content={Astro.generator} />
        <title>HumanSearch</title>
        <Font cssVariable='--font-lora' />
        <link
            rel='search'
            type='application/opensearchdescription+xml'
            title='HumanSearch'
            href='/opensearch.xml'
        />
    </head>
    <body class='h-screen w-full grid place-items-center'>
        <main class='w-fit flex flex-col gap-y-9'>
            <slot />
        </main>
        <footer
            class='absolute bottom-0 pb-6 w-full flex justify-center items-center gap-x-4 text-zinc-400'
        >
            <a
                href='/privacy-policy'
                class='text-sm gap-x-2 px-2 py-1 bg-linear-to-b from-zinc-50 to-zinc-200 text-zinc-800 rounded-lg cursor-default border-b-4 border border-zinc-400 shadow-md active:border-b-0 active:translate-y-1 active:shadow-none duration-100 transition-all'
                >privacy policy</a
            >
            <DotIcon />
            <a
                href='https://github.com/diodzi/human-search'
                target='_blank'
                class='text-sm gap-x-2 px-2 py-1 bg-linear-to-b from-zinc-50 to-zinc-200 text-zinc-800 rounded-lg cursor-default border-b-4 border border-zinc-400 shadow-md active:border-b-0 active:translate-y-1 active:shadow-none duration-100 transition-all'
                >source code</a
            >
            <DotIcon />
            <a
                href='https://diodzi.dev'
                target='_blank'
                class='text-sm gap-x-2 px-2 py-1 bg-linear-to-b from-zinc-50 to-zinc-200 text-zinc-800 rounded-lg cursor-default border-b-4 border border-zinc-400 shadow-md active:border-b-0 active:translate-y-1 active:shadow-none duration-100 transition-all'
                >made with &lt;3 by fellow human diodzi</a
            >
        </footer>
    </body>
</html>

<style>
    html {
        font-family: 'Helvetica';
    }
</style>

---
const { light = false, big = false, className, ...props } = Astro.props

const darkBtn = 'from-zinc-950 to-zinc-700 text-white border-black'
const lightBtn = 'from-zinc-50 to-zinc-200 text-zinc-800 border border-zinc-400'
const smBtn = 'px-2 py-1 gap-x-2 shadow-md text-sm'
const bigBtn = 'px-4 py-2 gap-x-3 shadow-lg'
---

<div
    {...props}
    class:list={[
        'flex items-center bg-linear-to-b rounded-lg cursor-default border-b-4 active:border-b-0 active:translate-y-1 active:shadow-none duration-100 transition-all',
        className,
        light ? lightBtn : darkBtn,
        big ? bigBtn : smBtn,
    ]}
>
    <slot />
</div>
